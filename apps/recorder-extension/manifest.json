{
  "manifest_version": 3,
  "name": "Tessera OS Recorder",
  "version": "1.0",
  "description": "Enterprise SOP and telemetry recorder",
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "all_frames": true
    }
  ],
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabs",
    "cookies"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://localhost:3000/*"
  ]
}
